{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:cas-msed:query-template:v1",
  "additionalProperties": false,
  "properties": {
    "filters": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "column": {
            "title": "Column",
            "type": "string"
          },
          "op": {
            "enum": [
              "eq",
              "in",
              "gte",
              "lte"
            ],
            "title": "Op",
            "type": "string"
          },
          "value": {
            "title": "Value"
          }
        },
        "required": [
          "column",
          "op",
          "value"
        ],
        "title": "FilterModel",
        "type": "object"
      },
      "title": "Filters",
      "type": "array"
    },
    "group_by": {
      "items": {
        "type": "string"
      },
      "title": "Group By",
      "type": "array"
    },
    "limit": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Limit"
    },
    "metrics": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "aggregate": {
            "enum": [
              "sum",
              "avg",
              "min",
              "max",
              "count"
            ],
            "title": "Aggregate",
            "type": "string"
          },
          "alias": {
            "minLength": 1,
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
            "title": "Alias",
            "type": "string"
          },
          "column": {
            "title": "Column",
            "type": "string"
          }
        },
        "required": [
          "column",
          "aggregate",
          "alias"
        ],
        "title": "MetricModel",
        "type": "object"
      },
      "minItems": 1,
      "title": "Metrics",
      "type": "array"
    },
    "sort": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "column": {
            "title": "Column",
            "type": "string"
          },
          "direction": {
            "enum": [
              "asc",
              "desc"
            ],
            "title": "Direction",
            "type": "string"
          }
        },
        "required": [
          "column",
          "direction"
        ],
        "title": "SortModel",
        "type": "object"
      },
      "title": "Sort",
      "type": "array"
    }
  },
  "required": [
    "metrics"
  ],
  "title": "QueryTemplateModel",
  "type": "object"
}
