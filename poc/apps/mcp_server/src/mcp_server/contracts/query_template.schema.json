{
  "$defs": {
    "Aggregate": {
      "enum": [
        "sum",
        "avg",
        "min",
        "max",
        "count"
      ],
      "title": "Aggregate",
      "type": "string"
    },
    "FilterModel": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "title": "Column",
          "type": "string"
        },
        "op": {
          "$ref": "#/$defs/Operator"
        },
        "value": {
          "title": "Value"
        }
      },
      "required": [
        "column",
        "op",
        "value"
      ],
      "title": "FilterModel",
      "type": "object"
    },
    "MetricModel": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "title": "Column",
          "type": "string"
        },
        "aggregate": {
          "$ref": "#/$defs/Aggregate"
        },
        "alias": {
          "minLength": 1,
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        }
      },
      "required": [
        "column",
        "aggregate",
        "alias"
      ],
      "title": "MetricModel",
      "type": "object"
    },
    "Operator": {
      "enum": [
        "eq",
        "in",
        "gte",
        "lte"
      ],
      "title": "Operator",
      "type": "string"
    },
    "SortDirection": {
      "enum": [
        "asc",
        "desc"
      ],
      "title": "SortDirection",
      "type": "string"
    },
    "SortModel": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "title": "Column",
          "type": "string"
        },
        "direction": {
          "$ref": "#/$defs/SortDirection"
        }
      },
      "required": [
        "column",
        "direction"
      ],
      "title": "SortModel",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "metrics": {
      "items": {
        "$ref": "#/$defs/MetricModel"
      },
      "minItems": 1,
      "title": "Metrics",
      "type": "array"
    },
    "filters": {
      "items": {
        "$ref": "#/$defs/FilterModel"
      },
      "title": "Filters",
      "type": "array"
    },
    "group_by": {
      "items": {
        "type": "string"
      },
      "title": "Group By",
      "type": "array"
    },
    "sort": {
      "items": {
        "$ref": "#/$defs/SortModel"
      },
      "title": "Sort",
      "type": "array"
    },
    "limit": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Limit"
    }
  },
  "required": [
    "metrics"
  ],
  "title": "QueryTemplateModel",
  "type": "object",
  "$id": "urn:cas-msed:query-template:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
